rules_version = '2';

// Regras de Segurança do Firestore para o Controle de Estudos.
// Garante que cada usuário só pode ler e escrever o PRÓPRIO documento — ninguém mais
// consegue ver ou alterar seus dados, nem mesmo outra pessoa que crie uma conta no mesmo projeto.
//
// COMO USAR: cole todo este conteúdo em Firebase Console → Firestore Database → Regras,
// substituindo o que já estiver lá, e clique em "Publicar".

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

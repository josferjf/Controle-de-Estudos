rules_version = '2';

// Regras de Segurança do Firebase Storage para o Controle de Estudos.
// Garante que cada usuário só pode enviar, ler e excluir os PRÓPRIOS arquivos (resumos em PDF).
//
// COMO USAR: Firebase Console → Storage → Regras, substitua o conteúdo por este e clique em "Publicar".

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
